{
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(supabase gen types:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase migration new:*)",
      "Bash(supabase migration list:*)",
      "Bash(supabase start)",
      "Bash(supabase stop)",
      "Bash(supabase status)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(npm --version)",
      "Bash(ls:*)",
      "Bash(find . -type f:*)"
    ],
    "deny": [
      "Bash(supabase db reset*)",
      "Bash(supabase db push*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf*)",
      "Bash(rm -r*)",
      "Write(./**/.env)",
      "Write(./**/.env.local)",
      "Write(./**/.env.production)",
      "Write(./**/.env.*.local)",
      "Write(./**/*secret*)",
      "Write(./**/*credentials*)"
    ]
  }
}
